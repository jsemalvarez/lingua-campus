// This is your Prisma schema file for Lingua Campus.
// It uses PostgreSQL for persistence and is designed for Multi-tenancy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// CORE TENANCY
enum InstitutePlan {
  BASIC
  STANDARD
  PREMIUM
}

model Institute {
  id          String   @id @default(cuid())
  name        String
  subdomain   String   @unique
  customDomain String? @unique
  plan        InstitutePlan @default(BASIC)
  address     String?
  phone       String?
  email       String?
  description String?
  logoUrl     String?
  facebookUrl String?
  instagramUrl String?
  whatsappNumber String?
  pwaIcon192 String?
  pwaIcon512 String?
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users         User[]
  students      Student[]
  courses       Course[]
  miscellaneousIncome MiscellaneousIncome[]
  expenses      Expense[]
  classrooms    Classroom[]
  levels        Level[]
  notifications Notification[]
}

// -----------------------------------------------------------------------------
// USERS & AUTH
// -----------------------------------------------------------------------------

enum UserRole {
  SUPERADMIN // All access (L-C devs)
  ADMIN      // Institute owner/admin
  TEACHER    // Staff member
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  role        UserRole @default(ADMIN)
  name        String     // Nombre Completo
  phone       String?    // Celular
  avatarUrl   String?
  status      String   @default("ACTIVE") // ACTIVE, DELETED
  preferences Json?      // Almacena preferencias visuales como ordenamiento de cursos
  
  instituteId String?
  institute   Institute? @relation(fields: [instituteId], references: [id])
  
  courses     Course[]   @relation("CourseTeacher")
  expensesReceived Expense[]  @relation("RecipientExpenses")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// BOARD: STUDENTS & ENROLLMENTS
// -----------------------------------------------------------------------------

model Student {
  id            String   @id @default(cuid())
  name          String
  email         String?  
  password      String?
  phone         String?
  address       String?
  dni           String?
  schoolInfo    String?
  registeredLevel String?
  status          String   @default("ACTIVE") // ACTIVE, DELETED
  
  // Tutor Legal 1
  guardian1Name     String?
  guardian1Relation String?
  guardian1Phone    String?
  
  // Tutor Legal 2
  guardian2Name     String?
  guardian2Relation String?
  guardian2Phone    String?
  birthDate     DateTime?
  joinDate      DateTime @default(now())

  // Billetera Virtual (Saldos a favor)
  creditBalance Float    @default(0)
  
  instituteId   String
  institute     Institute @relation(fields: [instituteId], references: [id])
  
  enrollments   Enrollment[]
  attendances   Attendance[]
  grades        Grade[]
  fees          Fee[]
  miscellaneousIncome MiscellaneousIncome[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([email, instituteId])
}

model Course {
  id          String   @id @default(cuid())
  name        String
  level       String?
  color       String   @default("#3b82f6") // Default blue-500
  status      String   @default("ACTIVE") // ACTIVE, FINISHED
  
  teacherId   String?
  teacher     User?     @relation("CourseTeacher", fields: [teacherId], references: [id])
  
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])

  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  enrollments Enrollment[]
  schedules   Schedule[]
  lessons     Lesson[]


  startDate   DateTime?
  endDate     DateTime?

  // Financials
  monthlyPrice   Float @default(0)
  enrollmentPrice Float @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Enrollment {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  
  enrolledAt  DateTime @default(now())
  status      String   @default("ACTIVE") // ACTIVE, FINISHED, INCOMPLETE

  // Custom Pricing (Scholarships)
  customMonthlyPrice   Float?
  customEnrollmentPrice Float?

  fees        Fee[]

  @@unique([studentId, courseId])
}

// -----------------------------------------------------------------------------
// ATTENDANCE & ACADEMICS
// -----------------------------------------------------------------------------

model Schedule {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  
  dayOfWeek   Int      // 0-6 (Sun-Sat)
  startTime   String   // HH:mm
  endTime     String   // HH:mm
  room        String?  // Ej: "Aula 1", "Laboratorio", etc

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons     Lesson[]
}

model Classroom {
  id          String    @id @default(cuid())
  name        String
  capacity    Int?
  
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  courses     Course[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, instituteId])
}

model Level {
  id          String    @id @default(cuid())
  name        String
  
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, instituteId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  JUSTIFIED
}

enum LessonType {
  CLASS
  TP
  EXAM
}

model Lesson {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  type        LessonType @default(CLASS)
  
  date        DateTime @db.Date
  topic       String
  content     String?  @db.Text
  
  attendances Attendance[]
  grades      Grade[]

  scheduleId  String?
  schedule    Schedule? @relation(fields: [scheduleId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  status      AttendanceStatus
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, lessonId])
}

model Grade {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  score       String?  // Can be a number like "8.5" or a letter like "A+"
  feedback    String?  @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([studentId, lessonId])
}

// -----------------------------------------------------------------------------
// FINANCIALS
// -----------------------------------------------------------------------------

enum TransactionType {
  PAYMENT        // Ingreso por Cuota/Matrícula
  EXPENSE        // Gasto común
  PAYROLL        // Pago de sueldo
  REFUND         // Devolución a un alumno
  MISC_INCOME    // Otros ingresos (libros, excursiones)
  ADJUSTMENT     // Ajustes de balance
}

enum TransactionStatus {
  VALID
  VOIDED     // Anulado por error humano
}

model Transaction {
  id          String   @id @default(cuid())
  instituteId String
  amount      Float    // Positivo para ingresos, Negativo para salidas
  type        TransactionType
  method      String   // EFECTIVO, TRANSFERENCIA, etc.
  date        DateTime @default(now())
  status      TransactionStatus @default(VALID)
  
  description String?  // Concepto

  // Enlaces a la entidad original (sólo uno tendrá valor)
  paymentId   String?
  payment     Payment? @relation(fields: [paymentId], references: [id])
  
  expenseId   String?
  expense     Expense? @relation(fields: [expenseId], references: [id])
  
  miscIncomeId String?
  miscIncome   MiscellaneousIncome? @relation(fields: [miscIncomeId], references: [id])

  operatorId  String?  // Id del usuario que registró el movimiento (opcional)
  
  createdAt   DateTime @default(now())
  
  @@index([instituteId])
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum FeeType {
  MONTHLY
  ENROLLMENT
}

model Fee {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  
  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id])

  type        FeeType @default(MONTHLY)
  
  originalAmount Float    // Precio base al momento de generar (Snapshot)
  paidAmount     Float    @default(0) // Suma de todos los pagos realizados
  
  year        Int
  month       Int      // 1-12
  status      PaymentStatus @default(PENDING)
  datePaid    DateTime?
  
  instituteId String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    Payment[]
}

model Payment {
  id          String   @id @default(cuid())
  feeId       String
  fee         Fee      @relation(fields: [feeId], references: [id])
  
  amount      Float
  surcharge   Float    @default(0)
  discount    Float    @default(0)
  method      String   // EFECTIVO, TRANSFERENCIA, etc.
  date        DateTime @default(now())
  notes       String?
  status      TransactionStatus @default(VALID)
  
  transactions Transaction[]
  
  createdAt   DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  date        DateTime @db.Date
  category    String   // Payroll, Rent, Utilities, etc.
  ticketNumber String?
  status      TransactionStatus @default(VALID)
  
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  
  recipientId String?
  recipient   User?     @relation("RecipientExpenses", fields: [recipientId], references: [id])

  transactions Transaction[]

  createdAt   DateTime @default(now())

  @@index([recipientId])
}

// -----------------------------------------------------------------------------
// NOTIFICATIONS
// -----------------------------------------------------------------------------

model Notification {
  id          String   @id @default(cuid())
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  type        String   // "NEW_ENROLLMENT", "PAYMENT_RECEIVED", etc.
  title       String
  body        String
  read        Boolean  @default(false)
  link        String?  // URL a donde navegar al hacer clic

  createdAt   DateTime @default(now())

  @@index([instituteId, read])
}

model MiscellaneousIncome {
  id           String    @id @default(cuid())
  description  String
  amount       Float
  date         DateTime  @db.Date
  category     String    // VENTA_LIBROS, EXCURSION, TALLER, OTROS
  method       String    // EFECTIVO, TRANSFERENCIA, etc.
  ticketNumber String?
  status       TransactionStatus @default(VALID)
  
  instituteId  String
  institute    Institute @relation(fields: [instituteId], references: [id])
  
  studentId    String?   // Opcional
  student      Student?  @relation(fields: [studentId], references: [id])

  transactions Transaction[]

  createdAt    DateTime  @default(now())

  @@index([instituteId])
  @@index([studentId])
}

